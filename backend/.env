# ── SePay ──────────────────────────────────────
# Lấy tại: sepay.vn → Cài đặt → API
SEPAY_APIKEY=your_sepay_api_key_here

# ── Google Apps Script ──────────────────────────
GAS_URL=https://script.google.com/macros/s/AKfycbwFi3Iq79XFFA9BBAUar9Ius727HeZncIHOVQdxMXczbpNRJ_TiBUgHnsI-YJDYnNl-ew/exec

# ── Email (Gmail) ───────────────────────────────
# Dùng App Password (không dùng mật khẩu Gmail thường)
# Tạo tại: myaccount.google.com → Bảo mật → Mật khẩu ứng dụng
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# ── Website ─────────────────────────────────────
SITE_URL=https://yourdomain.com

# ── Server ──────────────────────────────────────
PORT=3000
